{
  "name": "nx-resolve-affected",
  "description": "GitHub Action that resolves the NX affected deploy matrix per app using GitHub Deployments as the base SHA source",
  "version": "0.0.1",
  "author": "Rogier van Straten <rogier@from89.com>",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/rogiervanstraten/nx-resolve-affected",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogiervanstraten/nx-resolve-affected.git"
  },
  "bugs": {
    "url": "https://github.com/rogiervanstraten/nx-resolve-affected/issues"
  },
  "keywords": [
    "actions",
    "nx",
    "affected",
    "monorepo",
    "deployments"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@github/local-action": "^7.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.1",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@octokit/plugin-paginate-rest": "^11.3.6",
    "@octokit/request": "^9.1.3",
    "@octokit/request-error": "^6.1.5",
    "undici": ">=6.24.0"
  }
}
